BOT_TOKEN=your_telegram_bot_token_here
DB_PATH=data/property-bot.db

# Optional: timing (milliseconds)
# SESSION_TTL_MS=1800000
# SEARCH_COOLDOWN_MS=30000

# Optional: parser settings
# MAX_PARSER_PAGES=3
# REQUEST_TIMEOUT_MS=15000
# PAGE_DELAY_MS=1000

# Optional: UI
# RESULTS_PER_PAGE=5
# FAVORITES_PER_PAGE=5

# Optional: scheduler
# DIGEST_CRON=0 8 * * *
# DIGEST_TIMEZONE=Europe/Belgrade

# Optional: data retention
# PRICE_HISTORY_RETENTION_DAYS=90
