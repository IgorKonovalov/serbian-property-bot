# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Source
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf

# Config
*.env text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf

# Shell scripts
*.sh text eol=lf

# Git
.gitignore text eol=lf
.gitattributes text eol=lf

# Lock files
package-lock.json text eol=lf -diff

# Binary - do not normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
